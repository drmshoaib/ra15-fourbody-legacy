Cell[CellGroupData[{
Cell[BoxData[
    \(\(snum\  = \ 
      OpenRead["\<D:/STAFF/pk21220/4BIntegrationProject/Workingfolder/result.\
txt\>"]; \ndat = {}; \n
    For[i = 0, i < 99000, \n
      dat = Join[
          dat, {Read[snum, 
              \ {Number, \ Number, \ Number, \ Number, Number, \ Number, 
                Number, \ Number, Number}]}]; \(i++\)]; \nClose[snum]; \n
    t\  = \ \(Transpose[dat]\)[\([1]\)]; \n
    x1\  = \ \(Transpose[dat]\)[\([2]\)]; \n
    y1\  = \ \(Transpose[dat]\)[\([3]\)]; \n
    x2\  = \ \(Transpose[dat]\)[\([4]\)]; \n
    y2\  = \ \(Transpose[dat]\)[\([5]\)]; \n
    x3\  = \ \(Transpose[dat]\)[\([6]\)]; \n
    y3\  = \ \(Transpose[dat]\)[\([7]\)]; \n
    x4\  = \ \(Transpose[dat]\)[\([8]\)]; \n
    y4\  = \ \(Transpose[dat]\)[\([9]\)]; \n\nx1y1 = Transpose[{y1, x1}]; \n
    x2y2 = Transpose[{y2, x2}]; \nx3y3 = Transpose[{y3, x3}]; \n
    x4y4 = Transpose[{y4, x4}]; \n\n
    ListPlot[Join[x1y1, x2y2\ , \ x3y3, \ x4y4], 
      PlotRange -> {{\(-10\), 10}, {\(-20\), 20}}]; \n\n\n\n\n\)\)], "Input"],

