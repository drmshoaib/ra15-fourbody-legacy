Notebook[{

Cell[CellGroupData[{
Cell[BoxData[{
    \(snum\  = \ 
      OpenRead["\<D:/STAFF/pk21220/4BIntegrationProject/FourBody/result1.txt\>\
"]; \ndat = {}; \n
    For[i = 0, i < 3000, \n
      dat = Join[
          dat, {Read[snum, 
              \ {Number, \ Number, \ Number, \ Number, Number, \ Number, 
                Number, \ Number, Number, \ \ Number, \ Number, \ Number, 
                Number, \ Number, Number, \ Number, Number, \ Number}]}]; 
      \(i++\)]; \nClose[snum]; \nt\  = \ \(Transpose[dat]\)[\([1]\)]; \n
    x1\  = \ \(Transpose[dat]\)[\([2]\)]; \n
    y1\  = \ \(Transpose[dat]\)[\([3]\)]; \n
    x2\  = \ \(Transpose[dat]\)[\([4]\)]; \n
    y2\  = \ \(Transpose[dat]\)[\([5]\)]; \n
    x3\  = \ \(Transpose[dat]\)[\([6]\)]; \n
    y3\  = \ \(Transpose[dat]\)[\([7]\)]; \n
    x4\  = \ \(Transpose[dat]\)[\([8]\)]; \n
    y4\  = \ \(Transpose[dat]\)[\([9]\)]; \n
    v1x = \(Transpose[dat]\)[\([10]\)]; \nv1y = \(Transpose[dat]\)[\([11]\)]; 
    \nv2x = \(Transpose[dat]\)[\([12]\)]; \n
    v2y = \(Transpose[dat]\)[\([13]\)]; \nv3x = \(Transpose[dat]\)[\([14]\)]; 
    \nv3y = \(Transpose[dat]\)[\([15]\)]; \n
    v4x = \(Transpose[dat]\)[\([10]\)]; \nv4y = \(Transpose[dat]\)[\([11]\)]; 
    \nx1y1 = Transpose[{y1, x1}]; \nx2y2 = Transpose[{y2, x2}]; \n
    x3y3 = Transpose[{y3, x3}]; \nx4y4 = Transpose[{y4, x4}]; \n
    v1xy = Transpose[{v1x, v1y}]; \nv2xy = Transpose[{v2x, v2y}]; \n
    v3xy = Transpose[{v3x, v3y}]; \nv4xy = Transpose[{v4x, v4y}]; \n
    Ax = \((x1 + x3)\); \nAy = \((y1 + y3)\); \n\n
    Check1 = \((Ax)\)^2 + \((Ay)\)^2; \n
    Check2 = \((x2 + x4)\)^2 + \((y2 + y4)\)^2; 
    \n (*CheckPlot = Transpose[{Check1, Check2}]; *) \n\n\n\n
    ListPlot[Join[x1y1, x2y2\ , \ x3y3, \ x4y4]]; 
    \n (*ListPlot[Join[v1xy, v2xy\ , \ v3xy, \ v4xy], 
        PlotRange -> {{\(-1\), 1}, {\(-2\), 2}}]; *) \n\n
    ListPlot[CheckPlot (*, PlotRange -> {{\(-1\), 1}, {\(-2\), 2}}*) ]; \n
    pl = Join[{1000*t}, {Check1}]; \npll = Transpose[pl]; \nListPlot[pll]\n
    \), 
    \(p2 = Join[{1000*t}, {Check2}]; \npl2 = Transpose[p2]; \n
    ListPlot[pl2]\)}], "Input"],

Cell[GraphicsData["PostScript", "\<\
